# ── Claude (obrigatório) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Pexels (imagens e vídeos) ──────────────────────────────────────────────────
PEXELS_API_KEY=...

# ── Tavily (pesquisa de tendências) ───────────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ── Google Drive ───────────────────────────────────────────────────────────────
GOOGLE_DRIVE_FOLDER_ID=1AbC...xYz          # ID da pasta no Drive
GOOGLE_OAUTH_TOKEN={"token":"..."}         # JSON do token OAuth — cole o conteúdo de ~/.designer_ai_token.json

# ── Discord (aprovação de conteúdo) ──────────────────────────────────────────
DISCORD_BOT_TOKEN=...
DISCORD_CHANNEL_ID=...

# ── WhatsApp via Z-API (aprovação de conteúdo) ────────────────────────────────
# Documentação: https://developer.z-api.io
ZAPI_INSTANCE_ID=...
ZAPI_TOKEN=...
ZAPI_PHONE=5511999999999   # número do aprovador com DDI, sem + ou espaços

# ── Gemini (opcional — geração de imagens) ────────────────────────────────────
GEMINI_API_KEY=AIza...

# ── Instagram (auto-posting) ──────────────────────────────────────────────────
IG_USERNAME=seu_usuario_instagram
IG_PASSWORD=sua_senha_instagram
# Alternativa: session ID do browser (mais confiável que user/pass)
# Como obter: Instagram.com → DevTools (F12) → Application → Cookies → sessionid
IG_SESSION_ID=
